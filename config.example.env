# Telegram BotFather token.
TG_BOT_TOKEN=123456:replace_me

# Comma-separated numeric Telegram user IDs allowed to use the bot.
# The bot replies with your ID when an unknown user sends /start.
TG_ALLOWED_USER_IDS=123456789

# qBittorrent Web UI URL.
QBIT_URL=http://127.0.0.1:8080
QBIT_USER=admin
QBIT_PASS=replace_me
QBIT_VERIFY_TLS=true

# Optional qBittorrent add settings.
QBIT_SAVE_PATH=
QBIT_CATEGORY=telegram
QBIT_TAGS=telegram
QBIT_PAUSED=false

# Telegram Bot API getFile supports cloud downloads up to 20 MB.
MAX_TORRENT_BYTES=20971520

# Optional. Defaults to ~/.local/state/tg-qbit-bot.
STATE_DIR=
LOG_LEVEL=INFO
