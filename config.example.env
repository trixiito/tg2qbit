# Telegram BotFather token.
TG_BOT_TOKEN=123456:replace_me

# Comma-separated numeric Telegram user IDs allowed to use the bot.
# The bot replies with your ID when an unknown user sends /start.
TG_ALLOWED_USER_IDS=123456789
OWNER_USER_IDS=
ADMIN_USER_IDS=
VIEWER_USER_IDS=
APPROVAL_ENABLED=false
APPROVAL_TIMEOUT_SECONDS=3600

# qBittorrent Web UI URL.
QBIT_URL=http://127.0.0.1:8080
QBIT_USER=admin
QBIT_PASS=replace_me
QBIT_VERIFY_TLS=true

# Optional qBittorrent add settings.
QBIT_SAVE_PATH=
QBIT_CATEGORY=telegram
QBIT_TAGS=telegram
QBIT_PAUSED=false

# Optional category routing.
# Use torrent captions like "category: tv" or commands like "/add tv magnet:...".
# If a category is mapped here, the bot also sends it to that save path.
# Example: CATEGORY_SAVE_PATHS=tv=/srv/downloads/tv,movies=/srv/downloads/movies
CATEGORY_SAVE_PATHS=
CATEGORY_AS_TAG=false
TORRENT_PROFILES=
PER_CATEGORY_RATIO_TARGETS=

# Freeleech mode. Toggle at runtime with /freeleech on or /freeleech off.
FREELEECH_TAGS=freeleech
FREELEECH_CATEGORY=

# Telegram Bot API getFile supports cloud downloads up to 20 MB.
MAX_TORRENT_BYTES=20971520

# Background progress/status behavior.
PROGRESS_UPDATE_INTERVAL_SECONDS=180
PROGRESS_UPDATE_MAX_HOURS=24
STATUS_LIMIT=15
STATUS_LIVE_ENABLED=true
STATUS_REFRESH_SECONDS=30
STATUS_LIVE_DURATION_SECONDS=600
FUZZY_MATCH_MIN_SCORE=0.35
FUZZY_MATCH_LIMIT=5

# Disk space watchdog.
DISK_WATCH_ENABLED=true
DISK_WATCH_PATH=/
DISK_WATCH_THRESHOLDS=80,90,95
DISK_WATCH_INTERVAL_SECONDS=300

# Ratio alert. Set to 0 to disable.
RATIO_ALERT_TARGET=1.0
RATIO_ALERT_INTERVAL_SECONDS=300
RATIO_ACTION=notify
RATIO_ACTION_CATEGORY=

# Torrent health alerts.
STALLED_ALERT_ENABLED=true
STALLED_ALERT_MINUTES=30
LOW_SPEED_ALERT_ENABLED=true
LOW_SPEED_THRESHOLD_BYTES=51200
LOW_SPEED_MINUTES=30
TORRENT_ALERT_INTERVAL_SECONDS=900

# Completion automation. Options: notify, pause, delete, delete_data, category.
COMPLETION_ACTION=notify
COMPLETION_ACTION_CATEGORY=

# RSS watcher. Format:
# RSS_FEEDS=name|https://example.com/rss|optional-title-filter|optional-category;other|https://...
RSS_FEEDS=
RSS_INTERVAL_SECONDS=900

# Optional webhook mode. Usually run behind a reverse proxy with HTTPS.
WEBHOOK_ENABLED=false
WEBHOOK_HOST=127.0.0.1
WEBHOOK_PORT=8088
WEBHOOK_PATH=/telegram
WEBHOOK_URL=

# Optional. Defaults to ~/.local/state/tg-qbit-bot.
STATE_DIR=
LOG_LEVEL=INFO
